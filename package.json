{
  "name": "codequest",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @codequest/api & npm run dev --workspace @codequest/web",
    "build": "npm run build --workspaces",
    "typecheck": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace @codequest/api",
    "test:shared": "npm run test --workspace @codequest/shared",
    "lint": "npm run lint --workspaces --if-present",
    "format:check": "prettier --check \"apps/api/src/**/*.ts\" \"apps/api/tests/**/*.ts\" \"apps/web/src/**/*.{ts,tsx,css}\" \"packages/shared/src/**/*.ts\" package.json \"apps/*/package.json\" vercel.json",
    "validate": "npm run build && npm run lint && npm run format:check && npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace @codequest/api",
    "db:seed": "npm run db:seed --workspace @codequest/api"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "prettier": "^3.3.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.11.0"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma",
    "seed": "tsx apps/api/prisma/seed.ts"
  },
  "dependencies": {
    "@posthog/react": "^1.10.2",
    "posthog-js": "^1.391.2"
  }
}
