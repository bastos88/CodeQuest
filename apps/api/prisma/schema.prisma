generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  REVIEWER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum ReviewDecision {
  APPROVED
  REJECTED
}

enum MissionType {
  DAILY
  WEEKLY
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum ReportStatus {
  OPEN
  TRIAGED
  RESOLVED
  DISMISSED
}

enum GamificationEventType {
  QUIZ_COMPLETED
  QUIZ_PERFECT
  ACHIEVEMENT_UNLOCKED
  STREAK_BONUS
  DAILY_MISSION_COMPLETED
  CATEGORY_MASTERY
  CONTRIBUTION_APPROVED
  ARENA_WIN
  ARENA_LOSS
}

model User {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  passwordHash    String?
  provider        String?
  providerId      String?
  role            Role              @default(USER)
  avatarUrl       String?
  xp              Int               @default(0)
  rating          Int               @default(1000)
  quizzesCompleted Int              @default(0)
  correctAnswers  Int               @default(0)
  totalAnswers    Int               @default(0)
  streakDays      Int               @default(0)
  longestStreak   Int               @default(0)
  lastActivityAt  DateTime?
  activeTitleId   String?
  activeTitle     Title?            @relation("ActiveTitle", fields: [activeTitleId], references: [id])
  refreshTokens   RefreshToken[]
  oauthIdentities OAuthIdentity[]
  passwordResetTokens PasswordResetToken[]
  quizResults     QuizResult[]
  submittedQuestions Question[]     @relation("SubmittedQuestions")
  reviews         Review[]          @relation("ReviewerReviews")
  reports         Report[]
  achievements    UserAchievement[]
  titles          UserTitle[]
  missions        UserMission[]
  arenaAsA        ArenaMatch[]      @relation("ArenaA")
  arenaAsB        ArenaMatch[]      @relation("ArenaB")
  arenaWins       ArenaMatch[]      @relation("ArenaWinner")
  quizSessions    QuizSession[]
  activities      ActivityLog[]
  gamificationEvents GamificationEvent[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([provider, providerId])
}

model RefreshToken {
  id          String   @id @default(uuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  replacedBy  String?
  createdAt   DateTime @default(now())

  @@index([userId, expiresAt])
}

model OAuthIdentity {
  id         String   @id @default(uuid())
  provider   String
  providerId String
  email      String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([provider, providerId])
  @@unique([userId, provider])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Category {
  id          String               @id @default(uuid())
  name        String               @unique
  slug        String               @unique
  description String?
  questions   Question[]
  quizSessions QuizSession[]
  tracks      SkillTrackCategory[]
  createdAt   DateTime             @default(now())
}

model Question {
  id              String         @id @default(uuid())
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])
  authorId        String?
  author          User?          @relation("SubmittedQuestions", fields: [authorId], references: [id])
  prompt          String
  explanation     String?
  difficulty      Difficulty
  status          QuestionStatus @default(PENDING_REVIEW)
  isActive        Boolean        @default(false)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  usedCount       Int            @default(0)
  alternatives    Alternative[]
  quizAnswers     QuizAnswer[]
  reviews         Review[]
  reports         Report[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  archivedAt      DateTime?

  @@index([categoryId, difficulty, status, isActive, archivedAt])
}

model Alternative {
  id          String   @id @default(uuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text        String
  isCorrect   Boolean  @default(false)
  selectedAnswers QuizAnswer[] @relation("SelectedAlternative")
}

model QuizSession {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  difficulty  Difficulty?
  questionIds String[]
  submittedAt DateTime?
  createdAt   DateTime     @default(now())
  expiresAt   DateTime     @default(dbgenerated("(CURRENT_TIMESTAMP + '02:00:00'::interval)"))
  result       QuizResult?

  @@index([userId, createdAt])
  @@index([categoryId])
  @@index([expiresAt])
}

model QuizResult {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String       @unique
  session         QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  totalQuestions  Int
  correctCount    Int
  accuracy        Int
  xpEarned        Int
  durationSeconds Int
  answers         QuizAnswer[]
  createdAt       DateTime     @default(now())
  gamificationAppliedAt DateTime?

  @@index([userId, createdAt])
}

model QuizAnswer {
  id               String     @id @default(uuid())
  quizResultId     String
  quizResult       QuizResult @relation(fields: [quizResultId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question   @relation(fields: [questionId], references: [id])
  selectedOptionId String
  selectedOption   Alternative @relation("SelectedAlternative", fields: [selectedOptionId], references: [id], onDelete: Restrict)
  isCorrect        Boolean
  timeSpentSeconds Int

  @@index([quizResultId])
  @@index([questionId])
}

model Review {
  id          String         @id @default(uuid())
  questionId  String
  question    Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User           @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  decision    ReviewDecision
  checklist   Json?
  reason      String?
  createdAt   DateTime       @default(now())

  @@index([questionId, createdAt])
  @@index([reviewerId, createdAt])
}

model Report {
  id          String       @id @default(uuid())
  questionId  String
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason      String
  status      ReportStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model Achievement {
  id          String            @id @default(uuid())
  key         String            @unique
  name        String
  description String
  category    String
  tier        String?
  xpBonus     Int               @default(0)
  iconKey     String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
}

model GamificationEvent {
  id        String                  @id @default(uuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      GamificationEventType
  xpChange  Int
  metadata  Json?
  sourceKey String?                 @unique
  createdAt DateTime                @default(now())

  @@index([userId, createdAt])
}

model Title {
  id          String      @id @default(uuid())
  key         String      @unique
  name        String
  description String
  users       UserTitle[]
  activeUsers User[]      @relation("ActiveTitle")
}

model UserTitle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titleId   String
  title     Title    @relation(fields: [titleId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, titleId])
}

model SkillTrack {
  id          String               @id @default(uuid())
  name        String               @unique
  description String
  finalBadge  String
  categories  SkillTrackCategory[]
}

model SkillTrackCategory {
  id          String     @id @default(uuid())
  trackId     String
  track       SkillTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order       Int

  @@unique([trackId, categoryId])
}

model Mission {
  id          String        @id @default(uuid())
  key         String        @unique
  type        MissionType
  title       String
  target      Int
  xpReward    Int
  categorySlug String?
  description String        @default("")
  isActive     Boolean       @default(true)
  users       UserMission[]
}

model UserMission {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId   String
  mission     Mission       @relation(fields: [missionId], references: [id], onDelete: Cascade)
  progress    Int           @default(0)
  status      MissionStatus @default(ACTIVE)
  expiresAt   DateTime
  completedAt DateTime?

  @@unique([userId, missionId, expiresAt])
}

model ArenaMatch {
  id              String   @id @default(uuid())
  playerAId       String
  playerA         User     @relation("ArenaA", fields: [playerAId], references: [id])
  playerBId       String?
  playerB         User?    @relation("ArenaB", fields: [playerBId], references: [id])
  winnerId        String?
  winner          User?    @relation("ArenaWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  ratingDeltaA    Int      @default(0)
  ratingDeltaB    Int      @default(0)
  correctA        Int      @default(0)
  correctB        Int      @default(0)
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([playerAId, createdAt])
  @@index([playerBId, createdAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Season {
  id        String   @id @default(uuid())
  name      String
  startsAt  DateTime
  endsAt    DateTime
  rewards   Json?
  createdAt DateTime @default(now())
}
